# ============================================
# Casa Almeria — variáveis de ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores reais.
# Nunca commite o .env (já está no .gitignore).

# ----- Supabase (público / cliente) -----
# Usados pelo browser. SEGUROS para expor.
VITE_SUPABASE_URL=https://opbepcajjktehaezmqzf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Supabase (server-side / segredo) -----
# Usado APENAS pelas rotas /api/* para operações que bypassam RLS.
# NUNCA exponha publicamente. Configure no painel da Vercel como variável de ambiente,
# disponível apenas para Production/Preview (não Development se preferir).
EXTERNAL_SUPABASE_URL=https://opbepcajjktehaezmqzf.supabase.co
EXTERNAL_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role_jwt

# Feature flag — operação de pedidos v1 (preview; não ativar em produção sem aceite)
VITE_FEATURE_OPERACAO_PEDIDOS=false
FEATURE_OPERACAO_PEDIDOS=false

# ----- Resend (e-mail transacional — servidor apenas) -----
# Obtenha em https://resend.com/api-keys
# Substitua re_xxxxxxxxx pela sua chave real.
RESEND_API_KEY=re_xxxxxxxxx
# Remetente verificado no Resend (domínio grupoalmeria.com.br)
RESEND_FROM_EMAIL=atendimento@grupoalmeria.com.br

# ----- Segurança (documentação: docs/SECURITY.md) -----
# Desabilite sign-up público no painel Supabase (Authentication → Providers → Email).
# A migration 20260708_security_hardening.sql adiciona access_token em pedidos e hash de senhas.
